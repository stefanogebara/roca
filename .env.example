# OpenRouter (one key, all model tiers)
OPENROUTER_API_KEY=

# Model tiers (OpenRouter slugs; reason by tier, not version — override as models rotate)
ROCA_ROUTER_MODEL=anthropic/claude-haiku-4.5
ROCA_REASONING_MODEL=anthropic/claude-sonnet-5
ROCA_TRANSCRIBE_MODEL=google/gemini-2.5-flash

# Twilio WhatsApp Sandbox (Stage 0 transport)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Daily monitor cron auth (Vercel Cron sends "Authorization: Bearer <CRON_SECRET>")
CRON_SECRET=

# Founder ops console (/painel)
OPS_PASSWORD=
# Session-cookie HMAC key. Set it independently of CRON_SECRET (it falls back
# to CRON_SECRET with a logged warning) so rotating one never disturbs the other.
OPS_SESSION_SECRET=
# Bump to any new value to revoke every outstanding painel session at once.
OPS_TOKEN_VERSION=1

# Founder WhatsApp number (E.164, no "whatsapp:" prefix) to receive the daily
# digest. Optional — without it the digest is still stored and returned by the
# /api/cron/digest endpoint. Must have joined the Twilio sandbox to receive.
FOUNDER_WHATSAPP=

# Meta WhatsApp Cloud API (endgame transport — coexists with Twilio at one URL)
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
